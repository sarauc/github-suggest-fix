{
  "manifest_version": 3,
  "name": "PR Review AI Assistant",
  "version": "0.1.0",
  "description": "AI-powered help for understanding PR review comments",

  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://github.com/*",
    "http://127.0.0.1:8765/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
